{
  "name": "codemd-graphs",
  "displayName": "CODEMD",
  "description": "Pre-commit risk and impact analysis for developers and coding agents, powered by local CODEMD callgraphs and MCP.",
  "version": "0.0.56",
  "publisher": "codemd-dev",
  "homepage": "https://www.codemd.dev",
  "icon": "media/icon.png",
  "license": "SEE LICENSE IN LICENSE.txt",
  "repository": {
    "type": "git",
    "url": "https://github.com/pranaysaani/vscode-extension-graphs.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:codemdGraphs.panel",
    "onCommand:codemd",
    "onCommand:codemdGraphs.open",
    "onCommand:codemdGraphs.openEditor",
    "onCommand:codemdGraphs.generate",
    "onCommand:codemdGraphs.setupMcp",
    "onCommand:codemdGraphs.stopServer",
    "onCommand:codemdGraphs.openDebugLog",
    "onCommand:codemdlocal.generate",
    "onCommand:codemdLocal.generate"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codemdGraphs",
          "title": "CODEMD",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "codemdGraphs": [
        {
          "id": "codemdGraphs.panel",
          "name": "CODEMD",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "codemd",
        "title": "Open CODEMD"
      },
      {
        "command": "codemdGraphs.open",
        "title": "Open CODEMD"
      },
      {
        "command": "codemdGraphs.openEditor",
        "title": "Open CODEMD in Editor"
      },
      {
        "command": "codemdGraphs.generate",
        "title": "Generate CODEMD",
        "icon": "$(refresh)"
      },
      {
        "command": "codemdGraphs.setupMcp",
        "title": "CODEMD: Set Up MCP"
      },
      {
        "command": "codemdlocal.generate",
        "title": "Generate CODEMD"
      },
      {
        "command": "codemdLocal.generate",
        "title": "Generate CODEMD"
      },
      {
        "command": "codemdGraphs.stopServer",
        "title": "CODEMD: Stop Local Server"
      },
      {
        "command": "codemdGraphs.openDebugLog",
        "title": "CODEMD: Open Debug Log"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "codemdGraphs.generate",
          "when": "view == codemdGraphs.panel",
          "group": "navigation"
        }
      ]
    },
    "mcpServerDefinitionProviders": [
      {
        "id": "codemdGraphs.mcp",
        "label": "codemd"
      }
    ],
    "configuration": {
      "title": "CODEMD",
      "properties": {
        "codemdGraphs.autoWriteProjectMcpConfig": {
          "type": "boolean",
          "default": true,
          "description": "Write the project-scoped .mcp.json file when a workspace opens."
        },
        "codemdGraphs.autoReveal": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open the CODEMD panel when a workspace loads, so the callgraph appears without needing to click the CODEMD activity bar icon first."
        },
        "codemdGraphs.backendDir": {
          "type": "string",
          "default": "",
          "description": "Path to the folder containing the CODEMD analyzer backend (main.py). Leave empty to use the backend bundled with this extension. If no bundled backend is available, Generate CODEMD will prompt for an explicit backend folder."
        },
        "codemdGraphs.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Python executable used to launch the local FastAPI server. Leave unset (default) to have the extension auto-create and manage an isolated virtual environment with the required dependencies in global storage. Set this explicitly to use a specific interpreter instead — in that case it must already have backend/requirements.txt installed."
        },
        "codemdGraphs.analysisMode": {
          "type": "string",
          "enum": [
            "cli",
            "server"
          ],
          "default": "cli",
          "description": "How Generate CODEMD runs local analysis. Use cli for the default local subprocess path; use server to force the FastAPI workflow."
        },
        "codemdGraphs.host": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Host the local FastAPI server binds to."
        },
        "codemdGraphs.port": {
          "type": "number",
          "default": 8100,
          "description": "Port the local FastAPI server binds to."
        },
        "codemdGraphs.excludeGlobs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional glob patterns to exclude when zipping the workspace for analysis, on top of the built-in defaults (.git, node_modules, venvs, build output)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "copy-backend": "node scripts/copy-backend.js",
    "compile": "npm run copy-backend && tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "undici": "^8.7.0"
  }
}
